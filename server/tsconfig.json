{
    "compilerOptions": {
        "noEmit": true,
        "target": "esnext",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "verbatimModuleSyntax": true,
        "strict": true,
        "skipLibCheck": true,
        "types": [
            "node"
        ],
        "allowImportingTsExtensions": true,
        "erasableSyntaxOnly": true
    },
    "include": [
        "src",
        "../shared/types.ts"
    ]
}